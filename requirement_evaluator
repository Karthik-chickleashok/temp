from __future__ import annotations

import json
import re
from pathlib import Path
from typing import Any, Dict, List, Optional, Sequence, Set, Tuple


class RequirementEvaluator:
    """
    Evaluates extracted features against requirement definitions stored in
    requirements.json at the project root.

    Expected requirement shape:
    {
      "feature_name": "...",
      "category": "...",
      "description": "...",
      "conditions": {
        "must_have_keywords": [...],
        "must_not_have_keywords": [...],
        "must_have_flags": [...],
        "must_not_have_flags": [...]
      }
    }
    """

    def __init__(self, requirements_path: Optional[str | Path] = None) -> None:
        root_dir = Path(__file__).resolve().parent
        self.requirements_path: Path = Path(requirements_path) if requirements_path else root_dir / "requirements.json"
        self.requirements: List[Dict[str, Any]] = self._load_requirements()

    def evaluate(self, rows: List[Dict[str, Any]], features: Dict[str, Any]) -> Dict[str, Any]:
        """
        Evaluate all requirements dynamically using:
        - requirements.json
        - feature extractor output
        - normalized rows (currently kept for extensibility)
        """
        requirements = self.requirements
        keyword_index = self._build_keyword_index(features)
        normalized_feature_keywords = {
            self._normalize_text(k)
            for k in features.get("keywords", [])
            if k
        }
        feature_flags = self._normalize_flag_map(features.get("event_flags", {}))

        results: List[Dict[str, Any]] = []
        passed = 0
        failed = 0
        not_applicable = 0

        for req in requirements:
            result = self._evaluate_requirement(
                requirement=req,
                feature_keywords=normalized_feature_keywords,
                keyword_index=keyword_index,
                feature_flags=feature_flags,
                features=features,
            )
            results.append(result)

            status = result["status"]
            if status == "PASS":
                passed += 1
            elif status == "FAIL":
                failed += 1
            else:
                not_applicable += 1

        return {
            "summary": {
                "total": len(results),
                "passed": passed,
                "failed": failed,
                "not_applicable": not_applicable,
            },
            "results": results,
        }

    def _evaluate_requirement(
        self,
        requirement: Dict[str, Any],
        feature_keywords: Set[str],
        keyword_index: Dict[str, List[Tuple[Any, Any, Any, Any]]],
        feature_flags: Dict[str, bool],
        features: Dict[str, Any],
    ) -> Dict[str, Any]:
        feature_name = str(requirement.get("feature_name", ""))
        category = str(requirement.get("category", "GENERIC"))
        description = str(requirement.get("description", ""))
        conditions = requirement.get("conditions", {}) or {}

        must_have_keywords = self._normalize_list(conditions.get("must_have_keywords", []))
        must_not_have_keywords = self._normalize_list(conditions.get("must_not_have_keywords", []))
        must_have_flags = self._normalize_list(conditions.get("must_have_flags", []))
        must_not_have_flags = self._normalize_list(conditions.get("must_not_have_flags", []))

        evidence_keys: Set[Tuple[Any, Any, Any, Any]] = set()

        matched_must_have_keywords = self._find_matching_keywords(
            requirement_keywords=must_have_keywords,
            feature_keywords=feature_keywords,
            keyword_index=keyword_index,
            evidence_keys=evidence_keys,
        )

        matched_must_not_keywords = self._find_matching_keywords(
            requirement_keywords=must_not_have_keywords,
            feature_keywords=feature_keywords,
            keyword_index=keyword_index,
            evidence_keys=evidence_keys,
        )

        matched_must_have_flags = self._find_matching_flags(
            requirement_flags=must_have_flags,
            feature_flags=feature_flags,
        )

        matched_must_not_flags = self._find_matching_flags(
            requirement_flags=must_not_have_flags,
            feature_flags=feature_flags,
        )

        # Any forbidden match means FAIL
        has_forbidden_match = bool(matched_must_not_keywords or matched_must_not_flags)

        # All required items must match
        missing_required_keywords = len(matched_must_have_keywords) < len(must_have_keywords)
        missing_required_flags = len(matched_must_have_flags) < len(must_have_flags)

        # Determine whether this requirement is even relevant in current feature context
        referenced_keywords = set(self._normalize_text(x) for x in (
            must_have_keywords + must_not_have_keywords
        ) if x)

        referenced_flags = set(self._normalize_text(x).replace(" ", "_") for x in (
            must_have_flags + must_not_have_flags
        ) if x)

        any_keyword_relevant = self._any_requirement_keyword_relevant(
            referenced_keywords,
            feature_keywords,
            keyword_index,
        )

        any_flag_relevant = self._any_requirement_flag_relevant(
            referenced_flags,
            feature_flags,
        )

        any_relevant_context = any_keyword_relevant or any_flag_relevant

        if not any_relevant_context:
            status = "NOT_APPLICABLE"
        elif has_forbidden_match or missing_required_keywords or missing_required_flags:
            status = "FAIL"
        else:
            status = "PASS"

        details = {
            "matched_must_have_keywords": matched_must_have_keywords,
            "matched_must_not_have_keywords": matched_must_not_keywords,
            "matched_must_have_flags": matched_must_have_flags,
            "matched_must_not_have_flags": matched_must_not_flags,
        }

        evidence_count = len(evidence_keys) + len(matched_must_have_flags) + len(matched_must_not_flags)

        return {
            "feature_name": feature_name,
            "category": category,
            "description": description,
            "status": status,
            "details": details,
            "evidence_count": evidence_count,
        }

    def _load_requirements(self) -> List[Dict[str, Any]]:
        """
        Load requirements from JSON.
        If the file is missing, return an empty list instead of crashing.
        """
        if not self.requirements_path.exists():
            return []

        with open(self.requirements_path, "r", encoding="utf-8") as f:
            data = json.load(f)

        if not isinstance(data, list):
            raise ValueError("requirements.json must contain a list of requirement objects")

        normalized: List[Dict[str, Any]] = []
        for item in data:
            if isinstance(item, dict):
                normalized.append(item)

        return normalized

    def _build_keyword_index(self, features: Dict[str, Any]) -> Dict[str, List[Tuple[Any, Any, Any, Any]]]:
        """
        Build a searchable payload index from:
        - error_events
        - warning_events
        - evidence_refs

        Maps normalized payload text to evidence tuples:
        (line_no, timestamp, payload, source_file)
        """
        index: Dict[str, List[Tuple[Any, Any, Any, Any]]] = {}

        for section_name in ("error_events", "warning_events", "evidence_refs"):
            section = features.get(section_name, []) or []
            if not isinstance(section, list):
                continue

            for entry in section:
                if not isinstance(entry, dict):
                    continue

                payload = str(entry.get("payload", ""))
                normalized_payload = self._normalize_text(payload)
                if not normalized_payload:
                    continue

                evidence = (
                    entry.get("line_no", -1),
                    entry.get("timestamp", ""),
                    payload,
                    entry.get("source_file", ""),
                )
                index.setdefault(normalized_payload, []).append(evidence)

        return index

    def _find_matching_keywords(
        self,
        requirement_keywords: Sequence[str],
        feature_keywords: Set[str],
        keyword_index: Dict[str, List[Tuple[Any, Any, Any, Any]]],
        evidence_keys: Set[Tuple[Any, Any, Any, Any]],
    ) -> List[str]:
        """
        Find requirement keywords in:
        - features["keywords"]
        - payloads from indexed evidence sections
        """
        matched: List[str] = []

        for raw_keyword in requirement_keywords:
            keyword = self._normalize_text(raw_keyword)
            if not keyword:
                continue

            found = False

            # Exact match against extracted keywords
            if keyword in feature_keywords:
                matched.append(keyword)
                found = True

            # Match against payload evidence if not already found
            if not found:
                for payload_text, evidences in keyword_index.items():
                    if self._contains_term(payload_text, keyword):
                        matched.append(keyword)
                        found = True
                        for evidence in evidences:
                            evidence_keys.add(evidence)
                        break

        return matched

    def _find_matching_flags(
        self,
        requirement_flags: Sequence[str],
        feature_flags: Dict[str, bool],
    ) -> List[str]:
        """
        Match required flags that are True in feature_flags.
        """
        matched: List[str] = []

        for raw_flag in requirement_flags:
            normalized_flag = self._normalize_text(raw_flag).replace(" ", "_")
            if not normalized_flag:
                continue
            if feature_flags.get(normalized_flag, False):
                matched.append(normalized_flag)

        return matched

    def _normalize_flag_map(self, flags: Dict[str, Any]) -> Dict[str, bool]:
        normalized: Dict[str, bool] = {}
        if not isinstance(flags, dict):
            return normalized

        for key, value in flags.items():
            normalized_key = self._normalize_text(str(key)).replace(" ", "_")
            if normalized_key:
                normalized[normalized_key] = bool(value)

        return normalized

    def _normalize_list(self, values: Any) -> List[str]:
        if values is None:
            return []
        if isinstance(values, list):
            return [str(v) for v in values if v is not None]
        return [str(values)]

    def _normalize_text(self, text: Any) -> str:
        if text is None:
            return ""
        value = str(text).lower()
        value = re.sub(r"[_:/\\\-\[\]\(\)\{\}<>,;=|]+", " ", value)
        value = re.sub(r"\s+", " ", value).strip()
        return value

    def _contains_term(self, haystack: str, term: str) -> bool:
        if not haystack or not term:
            return False
        return re.search(rf"\b{re.escape(term)}\b", haystack) is not None

    def _any_requirement_keyword_relevant(
        self,
        referenced_keywords: Set[str],
        feature_keywords: Set[str],
        keyword_index: Dict[str, List[Tuple[Any, Any, Any, Any]]],
    ) -> bool:
        """
        Check whether any keyword mentioned in the requirement appears anywhere
        in the extracted feature context.
        """
        for keyword in referenced_keywords:
            if keyword in feature_keywords:
                return True
            for payload_text in keyword_index.keys():
                if self._contains_term(payload_text, keyword):
                    return True
        return False

    def _any_requirement_flag_relevant(
        self,
        referenced_flags: Set[str],
        feature_flags: Dict[str, bool],
    ) -> bool:
        """
        Check whether any flag mentioned in the requirement exists and is True.
        """
        for flag in referenced_flags:
            if feature_flags.get(flag, False):
                return True
        return False


if __name__ == "__main__":
    project_root = Path(__file__).resolve().parent
    parsed_path = project_root / "data" / "parsedlogs.json"
    features_path = project_root / "data" / "features.json"

    if not parsed_path.exists() or not features_path.exists():
        print("parsedlogs.json or features.json not found under data/")
    else:
        with open(parsed_path, "r", encoding="utf-8") as f:
            rows = json.load(f)

        with open(features_path, "r", encoding="utf-8") as f:
            features = json.load(f)

        evaluator = RequirementEvaluator(project_root / "requirements.json")
        result = evaluator.evaluate(rows, features)
        print(json.dumps(result, indent=2, ensure_ascii=False))
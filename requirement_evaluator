from pathlib import Path
code = r'''from __future__ import annotations

import json
import re
from pathlib import Path
from typing import Any, Dict, Iterable, List, Optional, Sequence, Set, Tuple


class RequirementEvaluator:
    """
    Evaluates extracted features against requirement definitions stored in
    requirements.json at the project root.

    Expected requirement shape:
    {
      "feature_name": "...",
      "category": "...",
      "description": "...",
      "conditions": {
        "must_have_keywords": [...],
        "must_not_have_keywords": [...],
        "must_have_flags": [...],
        "must_not_have_flags": [...]
      }
    }

    Evaluation rules:
    - If any must_not_have condition matches -> FAIL
    - If must_have exists but is not satisfied -> FAIL
    - Else -> PASS
    """

    def __init__(self, requirements_path: Optional[str | Path] = None) -> None:
        root_dir = Path(__file__).resolve().parent
        self.requirements_path: Path = Path(requirements_path) if requirements_path else root_dir / "requirements.json"
        self.requirements: List[Dict[str, Any]] = self._load_requirements()

    def evaluate(self, rows: List[Dict[str, Any]], features: Dict[str, Any]) -> Dict[str, Any]:
        requirements = self.requirements
        keyword_index = self._build_keyword_index(features)
        normalized_feature_keywords = {self._normalize_text(k) for k in features.get("keywords", []) if k}
        feature_flags = self._normalize_flag_map(features.get("event_flags", {}))

        results: List[Dict[str, Any]] = []
        passed = 0
        failed = 0

        for req in requirements:
            feature_name = str(req.get("feature_name", ""))
            category = str(req.get("category", "GENERIC"))
            conditions = req.get("conditions", {}) or {}

            must_have_keywords = self._normalize_list(conditions.get("must_have_keywords", []))
            must_not_have_keywords = self._normalize_list(conditions.get("must_not_have_keywords", []))
            must_have_flags = self._normalize_list(conditions.get("must_have_flags", []))
            must_not_have_flags = self._normalize_list(conditions.get("must_not_have_flags", []))

            evidence_keys: Set[Tuple[Any, Any, Any, Any]] = set()

            # Keyword matching domain:
            #   1) features["keywords"]
            #   2) payloads from error_events, warning_events, evidence_refs
            matched_must_have_keywords = self._find_matching_keywords(
                must_have_keywords,
                normalized_feature_keywords,
                keyword_index,
                evidence_keys,
            )
            matched_must_not_keywords = self._find_matching_keywords(
                must_not_have_keywords,
                normalized_feature_keywords,
                keyword_index,
                evidence_keys,
            )

            # Flag checks strictly against features["event_flags"]
            matched_must_have_flags = self._find_matching_flags(must_have_flags, feature_flags)
            matched_must_not_flags = self._find_matching_flags(must_not_have_flags, feature_flags)

            has_forbidden_match = bool(matched_must_not_keywords or matched_must_not_flags)
            missing_required_keywords = bool(must_have_keywords) and not bool(matched_must_have_keywords)
            missing_required_flags = bool(must_have_flags) and not bool(matched_must_have_flags)

            status = "PASS"
            if has_forbidden_match or missing_required_keywords or missing_required_flags:
                status = "FAIL"

            evidence_count = len(evidence_keys) + len(matched_must_have_flags) + len(matched_must_not_flags)

            if status == "PASS":
                passed += 1
            else:
                failed += 1

            results.append(
                {
                    "feature_name": feature_name,
                    "category": category,
                    "status": status,
                    "evidence_count": evidence_count,
                }
            )

        return {
            "summary": {
                "total": len(results),
                "passed": passed,
                "failed": failed,
            },
            "results": results,
        }

    def _load_requirements(self) -> List[Dict[str, Any]]:
        if not self.requirements_path.exists():
            raise FileNotFoundError(f"requirements.json not found: {self.requirements_path}")

        with open(self.requirements_path, "r", encoding="utf-8") as f:
            data = json.load(f)

        if not isinstance(data, list):
            raise ValueError("requirements.json must contain a list of requirement objects")

        normalized: List[Dict[str, Any]] = []
        for item in data:
            if isinstance(item, dict):
                normalized.append(item)
        return normalized

    def _build_keyword_index(self, features: Dict[str, Any]) -> Dict[str, List[Tuple[Any, Any, Any, Any]]]:
        """
        Build a search index from payload-bearing feature sections:
        - error_events
        - warning_events
        - evidence_refs

        The index maps normalized payload text to a list of evidence tuples.
        Evidence tuple format:
            (line_no, timestamp, payload, source_file)
        """
        index: Dict[str, List[Tuple[Any, Any, Any, Any]]] = {}
        for section_name in ("error_events", "warning_events", "evidence_refs"):
            section = features.get(section_name, []) or []
            if not isinstance(section, list):
                continue

            for entry in section:
                if not isinstance(entry, dict):
                    continue
                payload = str(entry.get("payload", ""))
                normalized_payload = self._normalize_text(payload)
                if not normalized_payload:
                    continue

                evidence = (
                    entry.get("line_no", -1),
                    entry.get("timestamp", ""),
                    payload,
                    entry.get("source_file", ""),
                )
                index.setdefault(normalized_payload, []).append(evidence)
        return index

    def _find_matching_keywords(
        self,
        requirement_keywords: Sequence[str],
        feature_keywords: Set[str],
        keyword_index: Dict[str, List[Tuple[Any, Any, Any, Any]]],
        evidence_keys: Set[Tuple[Any, Any, Any, Any]],
    ) -> List[str]:
        matched: List[str] = []
        for raw_keyword in requirement_keywords:
            keyword = self._normalize_text(raw_keyword)
            if not keyword:
                continue

            # Match in features["keywords"]
            if keyword in feature_keywords:
                matched.append(keyword)
                continue

            # Match against payloads from error_events, warning_events, evidence_refs
            found_in_payload = False
            for payload_text, evidences in keyword_index.items():
                if self._contains_term(payload_text, keyword):
                    matched.append(keyword)
                    found_in_payload = True
                    for evidence in evidences:
                        evidence_keys.add(evidence)
                    break

            if found_in_payload:
                continue

        return matched

    def _find_matching_flags(self, requirement_flags: Sequence[str], feature_flags: Dict[str, bool]) -> List[str]:
        matched: List[str] = []
        for raw_flag in requirement_flags:
            normalized_flag = self._normalize_text(raw_flag).replace(" ", "_")
            if not normalized_flag:
                continue
            if feature_flags.get(normalized_flag, False):
                matched.append(normalized_flag)
        return matched

    def _normalize_flag_map(self, flags: Dict[str, Any]) -> Dict[str, bool]:
        normalized: Dict[str, bool] = {}
        if not isinstance(flags, dict):
            return normalized
        for key, value in flags.items():
            normalized_key = self._normalize_text(str(key)).replace(" ", "_")
            if normalized_key:
                normalized[normalized_key] = bool(value)
        return normalized

    def _normalize_list(self, values: Any) -> List[str]:
        if values is None:
            return []
        if isinstance(values, list):
            return [str(v) for v in values if v is not None]
        return [str(values)]

    def _normalize_text(self, text: Any) -> str:
        if text is None:
            return ""
        value = str(text).lower()
        value = re.sub(r"[_:/\\\-\[\]\(\)\{\}<>,;=|]+", " ", value)
        value = re.sub(r"\s+", " ", value).strip()
        return value

    def _contains_term(self, haystack: str, term: str) -> bool:
        if not haystack or not term:
            return False
        return re.search(rf"\b{re.escape(term)}\b", haystack) is not None


if __name__ == "__main__":
    project_root = Path(__file__).resolve().parent
    parsed_path = project_root / "data" / "parsedlogs.json"
    features_path = project_root / "data" / "features.json"

    if not parsed_path.exists() or not features_path.exists():
        print("parsedlogs.json or features.json not found under data/")
    else:
        with open(parsed_path, "r", encoding="utf-8") as f:
            rows = json.load(f)
        with open(features_path, "r", encoding="utf-8") as f:
            features = json.load(f)

        evaluator = RequirementEvaluator(project_root / "requirements.json")
        result = evaluator.evaluate(rows, features)
        print(json.dumps(result, indent=2, ensure_ascii=False))
'''
path = Path('/mnt/data/requirement_evaluator.py')
path.write_text(code, encoding='utf-8')
print(path)
print(path.read_text(encoding='utf-8')[:500])

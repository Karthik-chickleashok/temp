from __future__ import annotations

from typing import Any, Dict, List, Optional


class DLTParser:
    """
    Simple text-based DLT parser.

    Expected flexible format per line:
    timestamp ECU APP CONTEXT LEVEL payload...

    Example:
    12:00:01.123 CCU2 SOMEIP SD INFO FindService sent
    12:00:03.456 CCU2 SOMEIP SD ERROR Timeout waiting for OfferService
    """

    def parse_file(self, file_path: str) -> List[Dict[str, Any]]:
        rows: List[Dict[str, Any]] = []

        with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
            for idx, line in enumerate(f, start=1):
                parsed = self._parse_line(line.rstrip("\n"), idx)
                if parsed is not None:
                    rows.append(parsed)

        return rows

    def _parse_line(self, line: str, line_no: int) -> Optional[Dict[str, Any]]:
        if not line or not line.strip():
            return None

        parts = line.split()

        if len(parts) < 5:
            return {
                "line_no": line_no,
                "timestamp": "",
                "ecu": "",
                "app": "",
                "context": "",
                "level": "",
                "payload": line.strip(),
            }

        timestamp = parts[0]
        ecu = parts[1]
        app = parts[2]
        context = parts[3]
        level = parts[4]
        payload = " ".join(parts[5:]) if len(parts) > 5 else ""

        return {
            "line_no": line_no,
            "timestamp": timestamp,
            "ecu": ecu,
            "app": app,
            "context": context,
            "level": level,
            "payload": payload,
        }
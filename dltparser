from __future__ import annotations

import datetime
import gzip
import hashlib
import json
import struct
from dataclasses import dataclass
from pathlib import Path
from typing import List, Optional, Sequence


@dataclass
class DLTMessage:
    """Represents one parsed DLT message."""
    index: int
    time: str
    timestamp: float
    count: int
    ecuId: str
    appId: str
    contextId: str
    sessionId: int
    type: str
    subtype: str
    mode: str
    nArgs: int
    payload: str

    def to_dict(self) -> dict:
        return self.__dict__

    @classmethod
    def from_dict(cls, data: dict) -> "DLTMessage":
        return cls(**data)


CONTROL_SERVICES = {
    0x01: "set_log_level",
    0x02: "set_trace_status",
    0x03: "get_log_info",
    0x04: "get_default_log_level",
    0x05: "store_config",
    0x06: "reset_to_factory_default",
    0x11: "set_default_log_level",
    0x12: "set_default_trace_status",
    0x13: "get_software_version",
    0xF01: "unregister_context",
    0xF02: "connection_info",
}

CONTROL_STATUS = {
    0x00: "ok",
    0x01: "not_supported",
    0x02: "error",
}


class DLTParser:
    """
    Binary DLT parser for .dlt and gzip-compressed .gz files.
    """

    CACHE_DIR = Path(".dlt_cache")
    VERSION = "1.0.0-ui"

    @staticmethod
    def clean_verbose(data: bytes) -> str:
        """Remove non-printables but preserve ANSI ESC."""
        chars: List[str] = []
        for b in data:
            if 32 <= b <= 126 or b == 27:
                chars.append(chr(b))
        return "".join(chars).strip()

    @staticmethod
    def clean_raw(data: bytes) -> str:
        """Replace non-printables with '-' in raw/non-verbose payloads."""
        chars: List[str] = []
        for b in data:
            if 32 <= b <= 126:
                chars.append(chr(b))
            else:
                chars.append("-")
        return "".join(chars)

    @classmethod
    def parse_file(cls, file_path_str: str, use_cache: bool = True) -> List[DLTMessage]:
        file_path = Path(file_path_str)

        if not file_path.exists():
            raise FileNotFoundError(f"File not found: {file_path}")

        cache_file: Optional[Path] = None

        if use_cache:
            cls.CACHE_DIR.mkdir(parents=True, exist_ok=True)
            sig = hashlib.md5(
                f"{file_path.resolve()}_{file_path.stat().st_size}_{cls.VERSION}".encode("utf-8")
            ).hexdigest()
            cache_file = cls.CACHE_DIR / f"{sig}.json"

            if cache_file.exists():
                with open(cache_file, "r", encoding="utf-8") as f:
                    return [DLTMessage.from_dict(item) for item in json.load(f)]

        with open(file_path, "rb") as f:
            buf = f.read()

        if buf.startswith(b"\x1f\x8b"):
            try:
                buf = gzip.decompress(buf)
            except Exception:
                pass

        messages = cls.parse_buffer(buf)

        if use_cache and cache_file is not None:
            with open(cache_file, "w", encoding="utf-8") as f:
                json.dump([m.to_dict() for m in messages], f, indent=2, ensure_ascii=False)

        return messages

    @classmethod
    def parse_buffer(cls, buf: bytes) -> List[DLTMessage]:
        messages: List[DLTMessage] = []
        offset = 0
        total = len(buf)
        global_index = 0

        last_sec = 0
        last_usec = 0
        last_ecu = "N/A"

        while offset < total:
            # Storage header
            if buf[offset:offset + 4] == b"DLT\x01":
                if offset + 16 > total:
                    break

                last_sec, last_usec = struct.unpack_from("<II", buf, offset + 4)
                last_ecu = (
                    buf[offset + 12:offset + 16]
                    .decode("ascii", "ignore")
                    .strip("\x00")
                    .strip()
                )
                offset += 16

            if offset + 4 > total:
                break

            htyp = buf[offset]
            mcnt = buf[offset + 1]
            length = struct.unpack_from(">H", buf, offset + 2)[0]

            if length < 4 or offset + length > total:
                offset += 1
                continue

            msg_buf = buf[offset:offset + length]
            header_offset = 4

            ecu_id = last_ecu
            session_id = 0
            timestamp_raw = 0

            # Standard header optional fields
            if htyp & 0x04:
                ecu_id = (
                    msg_buf[header_offset:header_offset + 4]
                    .decode("ascii", "ignore")
                    .strip("\x00")
                    .strip()
                )
                header_offset += 4

            if htyp & 0x08:
                session_id = struct.unpack_from(">I", msg_buf, header_offset)[0]
                header_offset += 4

            if htyp & 0x10:
                timestamp_raw = struct.unpack_from(">I", msg_buf, header_offset)[0]
                header_offset += 4

            use_ext_header = (htyp & 0x01) != 0
            msbf = (htyp & 0x02) != 0
            endian = ">" if msbf else "<"

            app_id = "N/A"
            context_id = "N/A"
            msg_type = "log"
            msg_subtype = "info"
            verbose_mode = False
            nargs = 0

            if use_ext_header:
                if header_offset + 10 > len(msg_buf):
                    offset += length
                    continue

                msin = msg_buf[header_offset]
                nargs = msg_buf[header_offset + 1]
                app_id = msg_buf[header_offset + 2:header_offset + 6].decode("ascii", "ignore").strip("\x00").strip()
                context_id = msg_buf[header_offset + 6:header_offset + 10].decode("ascii", "ignore").strip("\x00").strip()

                verbose_mode = (msin & 0x01) != 0
                mstp = (msin >> 1) & 0x07
                mtin = (msin >> 4) & 0x0F

                if mstp < 5:
                    msg_type = ["log", "app_trace", "nw_trace", "control", "unknown"][mstp]
                else:
                    msg_type = "unknown"

                if mstp == 0:
                    msg_subtype = ["", "fatal", "error", "warn", "info", "debug", "verbose"][mtin] if mtin < 7 else "info"
                elif mstp == 3:
                    msg_subtype = ["", "request", "response", "time"][mtin] if mtin < 4 else "request"

                header_offset += 10

            payload_parts: List[str] = []
            final_nargs = nargs

            # Control message decoding
            if msg_type == "control":
                final_nargs = 0
                if header_offset + 4 <= len(msg_buf):
                    ctrl_sid = struct.unpack_from(f"{endian}I", msg_buf, header_offset)[0]
                    svc_name = CONTROL_SERVICES.get(ctrl_sid, f"0x{ctrl_sid:02x}")

                    if msg_subtype == "response" and header_offset + 5 <= len(msg_buf):
                        status_byte = msg_buf[header_offset + 4]
                        payload_parts.append(f"[{svc_name} {CONTROL_STATUS.get(status_byte, str(status_byte))}]")
                        rem = msg_buf[header_offset + 5:]
                        if rem:
                            payload_parts.append(rem.hex(" "))
                    else:
                        payload_parts.append(f"[{svc_name}]")
                        rem = msg_buf[header_offset + 4:]
                        if rem:
                            payload_parts.append(rem.hex(" "))

            # Verbose payload decoding
            elif verbose_mode and nargs > 0:
                payload_offset = header_offset

                for _ in range(nargs):
                    if payload_offset + 4 > len(msg_buf):
                        break

                    type_info = struct.unpack_from(f"{endian}I", msg_buf, payload_offset)[0]
                    payload_offset += 4

                    # Variable name metadata
                    if type_info & 0x800:
                        if payload_offset + 2 > len(msg_buf):
                            break
                        name_len = struct.unpack_from(f"{endian}H", msg_buf, payload_offset)[0]
                        payload_offset += 2 + name_len

                    # Unit / info metadata
                    if type_info & 0xE0:
                        if payload_offset + 2 > len(msg_buf):
                            break
                        unit_len = struct.unpack_from(f"{endian}H", msg_buf, payload_offset)[0]
                        payload_offset += 2 + unit_len

                    type_len = type_info & 0x0F

                    # String
                    if type_info & 0x200:
                        if payload_offset + 2 > len(msg_buf):
                            break
                        str_len = struct.unpack_from(f"{endian}H", msg_buf, payload_offset)[0]
                        payload_offset += 2
                        raw = msg_buf[payload_offset:payload_offset + str_len]
                        text = raw.split(b"\x00")[0]
                        payload_parts.append(cls.clean_verbose(text))
                        payload_offset += str_len

                    # Bool
                    elif type_info & 0x10:
                        if payload_offset + 1 > len(msg_buf):
                            break
                        payload_parts.append("true" if msg_buf[payload_offset] else "false")
                        payload_offset += 1

                    # Signed / Unsigned integers
                    elif type_info & 0x40 or type_info & 0x20:
                        size = {1: 1, 2: 2, 3: 4, 4: 8}.get(type_len, 1)
                        if payload_offset + size > len(msg_buf):
                            break

                        if type_info & 0x20:
                            fmt_map = {1: "b", 2: "h", 4: "i", 8: "q"}
                        else:
                            fmt_map = {1: "B", 2: "H", 4: "I", 8: "Q"}

                        fmt = fmt_map[size]
                        value = struct.unpack_from(f"{endian}{fmt}", msg_buf, payload_offset)[0]

                        if type_info & 0x10000:
                            payload_parts.append(f"0x{value:x}")
                        else:
                            payload_parts.append(str(value))

                        payload_offset += size

                    # Float
                    elif type_info & 0x80:
                        size = 4 if type_len == 3 else 8
                        if payload_offset + size > len(msg_buf):
                            break

                        if size == 4:
                            value = struct.unpack_from(f"{endian}f", msg_buf, payload_offset)[0]
                        else:
                            value = struct.unpack_from(f"{endian}d", msg_buf, payload_offset)[0]

                        payload_parts.append(f"{value:.3f}".rstrip("0").rstrip("."))
                        payload_offset += size

                    # Raw / blob
                    elif type_info & 0x400:
                        if payload_offset + 2 > len(msg_buf):
                            break
                        raw_len = struct.unpack_from(f"{endian}H", msg_buf, payload_offset)[0]
                        payload_offset += 2
                        payload_parts.append(msg_buf[payload_offset:payload_offset + raw_len].hex(" "))
                        payload_offset += raw_len

                    else:
                        break

            # Non-verbose fallback
            else:
                final_nargs = 0
                if header_offset + 4 <= len(msg_buf):
                    msg_id = struct.unpack_from(f"{endian}I", msg_buf, header_offset)[0]
                    raw_tail = msg_buf[header_offset + 4:]
                    payload_parts.append(f"[{msg_id}] {cls.clean_raw(raw_tail)}")
                else:
                    raw_tail = msg_buf[header_offset:]
                    payload_parts.append(cls.clean_raw(raw_tail))

            dt = datetime.datetime.fromtimestamp(last_sec, datetime.timezone.utc) + datetime.timedelta(hours=1)

            messages.append(
                DLTMessage(
                    index=global_index,
                    time=dt.strftime("%Y/%m/%d %H:%M:%S") + f".{last_usec:06d}",
                    timestamp=round(timestamp_raw / 10000.0, 4),
                    count=mcnt,
                    ecuId=ecu_id,
                    appId=app_id,
                    contextId=context_id,
                    sessionId=session_id,
                    type=msg_type,
                    subtype=msg_subtype,
                    mode="verbose" if verbose_mode else "non-verbose",
                    nArgs=final_nargs,
                    payload=" ".join(part for part in payload_parts if part).strip(),
                )
            )

            offset += length
            global_index += 1

        return messages


class DLTController:
    """
    Controller for parsing one file, multiple files, or a folder.
    """

    SUPPORTED_EXTENSIONS = {".dlt", ".gz"}

    def collect_supported_files_from_folder(self, folder: str | Path) -> List[Path]:
        folder_path = Path(folder)

        if not folder_path.exists():
            raise FileNotFoundError(f"Folder not found: {folder_path}")

        files: List[Path] = []
        for p in sorted(folder_path.iterdir()):
            if p.is_file() and p.suffix.lower() in self.SUPPORTED_EXTENSIONS:
                files.append(p)

        return files

    def parse_file(self, file_path: str | Path) -> List[DLTMessage]:
        return DLTParser.parse_file(str(file_path))

    def parse_files(self, file_paths: Sequence[str | Path]) -> List[DLTMessage]:
        all_messages: List[DLTMessage] = []
        global_index = 0

        for fp in file_paths:
            msgs = self.parse_file(fp)
            for msg in msgs:
                msg.index = global_index
                global_index += 1
                all_messages.append(msg)

        return all_messages

    def parse_path(self, path: str | Path) -> List[DLTMessage]:
        p = Path(path)

        if p.is_file():
            return self.parse_file(p)

        if p.is_dir():
            files = self.collect_supported_files_from_folder(p)
            return self.parse_files(files)

        raise FileNotFoundError(f"Input path not found: {p}")